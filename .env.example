# ============================================================
# Explainer Video Factory — Environment Configuration
# ============================================================
# Copy this file to .env and customize as needed.
# All values shown are defaults.

# ---------- General ----------
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
LOG_FORMAT=console

# ---------- Output ----------
OUTPUT_DIR=./outputs
TEMP_DIR=./tmp
MAX_VIDEO_DURATION_SECONDS=600

# ---------- TTS Engine ----------
TTS_VOICE=en-US-AriaNeural
TTS_RATE=+0%
TTS_VOLUME=+0%

# ---------- Video Settings ----------
VIDEO_WIDTH=1920
VIDEO_HEIGHT=1080
VIDEO_FPS=24
VIDEO_CODEC=libx264
VIDEO_BITRATE=4000k
AUDIO_CODEC=aac
AUDIO_BITRATE=192k

# ---------- Visual Theme ----------
THEME_NAME=default
THEME_PRIMARY_COLOR=#4F46E5
THEME_SECONDARY_COLOR=#7C3AED
THEME_BG_COLOR=#0F172A
THEME_TEXT_COLOR=#F8FAFC
THEME_ACCENT_COLOR=#06B6D4

# ---------- LLM (Optional) ----------
# Set these to enable LLM-powered script generation.
# Without these, the system uses template-based generation.
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=gpt-4
# LLM_TEMPERATURE=0.7
# LLM_MAX_TOKENS=4096

# ---------- API Server ----------
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
